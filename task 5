import java.util.Scanner;

public class FaceDetectionRecognition {

    public static void detectFace(String imageName) {
        System.out.println("Scanning image: " + imageName);

        
        System.out.println("Face Detected Successfully!");
    }

    public static void recognizeFace(String personName) {
        
        System.out.println("Recognizing face...");

        if (personName.equalsIgnoreCase("Siva")) {
            System.out.println("Person Recognized: Siva");
        } else {
            System.out.println("Unknown Person");
        }
    }

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        System.out.print("Enter image name: ");
        String image = sc.nextLine();

        detectFace(image);

        System.out.print("Enter person name for recognition: ");
        String name = sc.nextLine();

        recognizeFace(name);

        sc.close();
    }
}
